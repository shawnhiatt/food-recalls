# openFDA API key (free): https://open.fda.gov/apis/authentication/
# Set in the Convex deployment environment, not locally:
#   npx convex env set OPENFDA_API_KEY <key>
OPENFDA_API_KEY=

# Convex deployment (written by `npx convex dev` on first run)
CONVEX_DEPLOYMENT=

# Convex client URL for the Next.js frontend (also written by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=

# --- Phase 2: email notifications (SPEC.md §9) ---
# Resend API key + verified sender. Notifications no-op (with a logged warning)
# if either is unset, so dev/test never require live mail.
#   npx convex env set RESEND_API_KEY <key>
#   npx convex env set RESEND_FROM "Food Recalls <alerts@yourdomain>"
RESEND_API_KEY=
RESEND_FROM=
# Where source-health degradation self-alerts go (§10). Optional; skipped if unset.
#   npx convex env set OPERATOR_EMAIL <you@example.com>
OPERATOR_EMAIL=
# Base URL for deep links in emails (defaults to https://foodrecalls.app).
#   npx convex env set APP_BASE_URL https://your-deployment.vercel.app
APP_BASE_URL=

# --- Phase 3: web push notifications (SPEC.md §9) ---
# VAPID keypair for the Web Push protocol. Generate once with:
#   npx web-push generate-vapid-keys
# then set the private half + subject on Convex (never NEXT_PUBLIC_):
#   npx convex env set VAPID_PUBLIC_KEY <public key>
#   npx convex env set VAPID_PRIVATE_KEY <private key>
#   npx convex env set VAPID_SUBJECT "mailto:you@example.com"
# Sends no-op (with a logged warning) if either key is unset, so dev/test
# never require live push. Mirror the PUBLIC key here too — it's not secret,
# the client needs it to call PushManager.subscribe():
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Pilot access gate for the read-only Household tab (SPEC.md §2) — household
# preferences must never be publicly queryable, even with no auth yet.
# Set the SAME value in both places; never prefix it NEXT_PUBLIC_, or it
# ships to the browser and defeats the gate:
#   npx convex env set PILOT_ACCESS_SECRET <a long random value>
# then put the identical value here in .env.local (server-only, read by the
# Household page's Server Component).
PILOT_ACCESS_SECRET=
