{
  "name": "food-recalls",
  "version": "0.1.0",
  "private": true,
  "description": "Food Recalls — recalls that actually apply to you. Household food-safety monitoring: ingests federal recall and outbreak data, enriches it, and matches it against your household.",
  "scripts": {
    "dev": "convex dev",
    "dev:web": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.convex.json --noEmit && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "seed": "convex run seed:seedDefaultHousehold"
  },
  "dependencies": {
    "convex": "^1.17.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serwist": "^9.0.11"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^4.0.0",
    "@serwist/next": "^9.0.11",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "convex-test": "^0.0.35",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
